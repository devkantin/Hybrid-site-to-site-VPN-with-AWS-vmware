# Terraform state — never commit state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Local variable overrides with real values
terraform.tfvars
*.auto.tfvars

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Sensitive override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files
*.tfplan

# OS artifacts
.DS_Store
Thumbs.db
